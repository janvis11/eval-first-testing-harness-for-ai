SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-or-service-role-key
REDIS_URL=redis://localhost:6379/0

PII_SAFE_ENV=development
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8000
WORKERS=4

# Set a strong secret key in production (min 32 chars)
SECRET_KEY=change-me-in-production-min-32-chars

# Rate Limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_BURST=10
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=100
ENABLE_RATE_LIMIT=true

# Request Size Limit (KB)
MAX_REQUEST_SIZE_KB=1024

# CORS Origins (JSON array format)
CORS_ORIGINS=["http://localhost:3000"]

AUDIT_LOG_ENABLED=true
AUDIT_LOG_RETENTION_DAYS=90
AUDIT_LOG_PII_REDACTION=true
DEFAULT_TENANT_ID=default
DEFAULT_TENANT_NAME=Default Tenant
DEFAULT_API_KEY_SCOPES=admin
DEV_MODE_AUTO_CREATE_DEFAULT_KEY=true

PSEUDONYMIZATION_SALT=change-me-in-production

DETECTOR_ENABLE_LUHN=true
DETECTOR_EXCLUDE_TEST_DOMAINS=true
DETECTOR_TEST_DOMAINS=example.com,test.com,localhost
DETECTOR_ENABLE_SSN_VALIDATION=true
DETECTOR_ENABLE_CARD_TYPE=true
DETECTOR_MIN_PHONE_DIGITS=10
DETECTOR_MAX_PHONE_DIGITS=15

SANITIZER_REDACTION_PREFIX=
SANITIZER_TOKEN_LENGTH=8

MIDDLEWARE_EXCLUDE_PATHS=/health,/docs,/redoc,/openapi.json,/
MIDDLEWARE_ENABLE_LOGGING=true
MIDDLEWARE_ENABLE_HEADERS=true
MIDDLEWARE_MAX_AUDIT_SIZE=10000

# Weights for each entity type (higher = more sensitive)
RISK_SSN_WEIGHT=1.0
RISK_CC_WEIGHT=1.0
RISK_EMAIL_WEIGHT=0.5
RISK_PHONE_WEIGHT=0.5
RISK_IP_WEIGHT=0.3
RISK_NAME_WEIGHT=0.4
RISK_CUSTOM_WEIGHT=0.2

# Auto-block threshold (0.0-1.0)
RISK_BLOCK_THRESHOLD=0.9
